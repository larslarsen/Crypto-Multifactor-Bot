{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cryptofactors.local/schemas/hypothesis.schema.json",
  "title": "HypothesisVersion",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "hypothesis_id",
    "version",
    "slug",
    "title",
    "statement",
    "mechanism",
    "expected_sign",
    "lifecycle",
    "verdict",
    "phase",
    "primary_metric",
    "advancement_rule",
    "rejection_rule"
  ],
  "properties": {
    "hypothesis_id": {
      "type": "string",
      "pattern": "^H-[0-9]{3,}$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "statement": {
      "type": "string",
      "minLength": 20
    },
    "mechanism": {
      "type": "string",
      "minLength": 10
    },
    "expected_sign": {
      "type": "string"
    },
    "lifecycle": {
      "enum": [
        "DRAFT",
        "REGISTERED",
        "ACTIVE",
        "DEFERRED",
        "CLOSED"
      ]
    },
    "verdict": {
      "enum": [
        "UNTESTED",
        "PRELIMINARY",
        "SUPPORTED",
        "REPLICATED",
        "NOT_REPLICATED",
        "REJECTED",
        "INCONCLUSIVE",
        "QUARANTINED"
      ]
    },
    "phase": {
      "type": "string"
    },
    "primary_metric": {
      "type": "string",
      "minLength": 3
    },
    "advancement_rule": {
      "type": "string",
      "minLength": 10
    },
    "rejection_rule": {
      "type": "string",
      "minLength": 10
    },
    "known_confounders": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "required_dataset_types": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "preregistered_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  }
}
