{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cryptofactors.local/schemas/evidence_snapshot.schema.json",
  "title": "EvidenceSnapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "snapshot_id",
    "hypothesis_id",
    "hypothesis_version",
    "as_of",
    "generated_at",
    "evidence_ids",
    "content_sha256"
  ],
  "properties": {
    "snapshot_id": {
      "type": "string"
    },
    "hypothesis_id": {
      "type": "string"
    },
    "hypothesis_version": {
      "type": "integer",
      "minimum": 1
    },
    "as_of": {
      "type": "string",
      "format": "date-time"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "content_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "artifact_uri": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
