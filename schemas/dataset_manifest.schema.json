{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Immutable Dataset Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "dataset_id",
    "dataset_type",
    "schema_version",
    "transform",
    "code_commit",
    "config_sha256",
    "dependencies",
    "files",
    "row_count",
    "byte_size",
    "quality_status",
    "created_at"
  ],
  "properties": {
    "dataset_id": {
      "type": "string",
      "pattern": "^ds_[a-f0-9]{64}$"
    },
    "dataset_type": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "transform": {
      "type": "object",
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "code_commit": {
      "type": "string",
      "minLength": 7
    },
    "config_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "role"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "enum": [
              "RAW_OBJECT",
              "DATASET"
            ]
          },
          "role": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "sha256",
          "uri",
          "rows",
          "bytes"
        ],
        "properties": {
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "uri": {
            "type": "string"
          },
          "rows": {
            "type": "integer",
            "minimum": 0
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          },
          "partition": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    "row_count": {
      "type": "integer",
      "minimum": 0
    },
    "byte_size": {
      "type": "integer",
      "minimum": 0
    },
    "event_start": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "event_end": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "availability_start": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "availability_end": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "quality_status": {
      "enum": [
        "PASS",
        "PASS_WITH_WARNINGS",
        "QUARANTINED",
        "REJECTED"
      ]
    },
    "quality_summary": {
      "type": "object"
    },
    "supersedes_dataset_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
