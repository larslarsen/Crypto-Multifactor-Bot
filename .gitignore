# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.installed.cfg
.venv/
venv/
ENV/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Research data (large / proprietary / regenerable) — keep specs + registries,
# not raw observations. Ignore actual data directories; do NOT blanket-ignore
# *.csv/*.parquet because the research package legitimately commits registry
# CSVs and small fixtures (per architecture: registries are publishable).
data/
raw_*/
cache/
*.pkl
*.joblib
*.h5

# Local data root lives OUTSIDE the repo (e.g. ~/cryptofactors_data)

# Editor / OS
.vscode/
.idea/
.DS_Store
*.swp

# Local secrets / credentials
.env
*.key
secrets.*

# Logs
*.log
logs/
